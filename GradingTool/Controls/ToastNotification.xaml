<UserControl x:Class="GradingTool.Controls.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ToastControl">
    <Border Background="#2E7D32"
            CornerRadius="6"
            Padding="16,12"
            MinWidth="250"
            MaxWidth="400">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" 
                            ShadowDepth="2" 
                            Opacity="0.3"/>
        </Border.Effect>
        <TextBlock Text="{Binding Message, ElementName=ToastControl}"
                   Foreground="White"
                   FontSize="13"
                   TextWrapping="Wrap"/>
    </Border>
</UserControl>
