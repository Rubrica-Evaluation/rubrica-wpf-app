<UserControl x:Class="GradingTool.Views.ConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{DynamicResource Config_Title}" FontSize="20" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="{DynamicResource Common_Back}" Command="{Binding GoBackCommand}" Style="{StaticResource GhostButton}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Vertical">
            <!-- Dossier racine -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Config_RootFolder}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource Config_RootFolderDescription}"
                               FontSize="12" Foreground="#666666" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding SessionsRootPath, FallbackValue='Non configuré'}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#333333"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0"/>

                        <Button Grid.Column="1"
                                Content="{Binding SelectFolderButtonText}"
                                Command="{Binding SelectSessionsRootCommand}"
                                Style="{StaticResource RoundedButton}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Langue -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Config_Language}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource Config_LanguageDescription}"
                               FontSize="12" Foreground="#666666" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Français"
                                     IsChecked="{Binding SelectedLanguage, Converter={StaticResource GenerationModeConverter}, ConverterParameter=fr}"
                                     GroupName="Language"
                                     FontSize="14"
                                     Margin="0,0,24,0"/>
                        <RadioButton Content="English"
                                     IsChecked="{Binding SelectedLanguage, Converter={StaticResource GenerationModeConverter}, ConverterParameter=en}"
                                     GroupName="Language"
                                     FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Copies de sauvegardes -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="16" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Config_Backup}" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource Config_BackupDescription}"
                               FontSize="12" Foreground="#666666" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <CheckBox Content="{DynamicResource Config_BackupEnabled}"
                              IsChecked="{Binding IsBackupEnabled}"
                              FontSize="14"
                              Margin="0,0,0,12"/>

                    <StackPanel Visibility="{Binding IsBackupEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Config_BackupInterval}"
                                       FontSize="13" Foreground="#444444" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding BackupIntervalOptions}"
                                      SelectedItem="{Binding SelectedBackupIntervalMinutes}"
                                      Style="{StaticResource ModernComboBox}"
                                      MinWidth="70" FontSize="13"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Config_BackupMaxCount}"
                                       FontSize="13" Foreground="#444444" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="6"
                                      ItemsSource="{Binding BackupMaxCountOptions}"
                                      SelectedItem="{Binding SelectedBackupMaxCount}"
                                      Style="{StaticResource ModernComboBox}"
                                      MinWidth="55" FontSize="13"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Config_BackupAvailable}"
                                   FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>

                        <ListBox ItemsSource="{Binding AvailableBackups}"
                                 SelectedItem="{Binding SelectedBackup}"
                                 MaxHeight="150"
                                 BorderBrush="#E8E8E8"
                                 BorderThickness="1"
                                 Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" Padding="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="{DynamicResource Config_BackupRestore}"
                                Command="{Binding RestoreBackupCommand}"
                                Style="{StaticResource RoundedButton}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Version -->
            <Border Background="#FAFAFA" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource Config_Version}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{DynamicResource Config_VersionDescription}"
                                   FontSize="12"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#F1F3F5"
                            CornerRadius="999"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
