<Window x:Class="GradingTool.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GradingTool.Models"
        Title="{Binding Title}"
        Width="480"
        Height="220"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Prompt}"
                   FontSize="13"
                   Foreground="#333333"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBox Grid.Row="1"
                 x:Name="InputTextBox"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="13"
                 Padding="8"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1"
                 Margin="0,0,0,12"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"/>

        <CheckBox Grid.Row="2"
                  x:Name="AddToBankCheckBox"
                  Content="Ajouter à la banque de commentaires"
                  IsChecked="{Binding AddedToBank}"
                  FontSize="12"
                  Foreground="#555555"
                  Margin="0,0,0,12"
                  Visibility="{Binding AddToBankVisible}"/>

        <!-- Sévérité (visible uniquement lors d'un ajout à la banque ou d'une modification) -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,12"
                    Visibility="{Binding SeverityVisible}">
            <TextBlock Text="Sévérité :"
                       FontSize="12"
                       Foreground="#555555"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding SeverityValues}"
                      SelectedItem="{Binding SelectedSeverity, Mode=TwoWay}"
                      Width="140"
                      Style="{StaticResource ModernComboBox}"/>
        </StackPanel>

        <CheckBox Grid.Row="4"
                  Content="Modifier le commentaire équivalent dans la banque"
                  IsChecked="{Binding UpdateBankInPlace}"
                  FontSize="12"
                  Foreground="#555555"
                  Margin="0,0,0,12"
                  Visibility="{Binding UpdateBankVisible}"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Annuler"
                    Click="Cancel_Click"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    Style="{StaticResource GhostButton}"/>
            <Button Content="OK"
                    Click="OK_Click"
                    IsDefault="True"
                    Padding="16,8"
                    Style="{StaticResource RoundedButton}"/>
        </StackPanel>
    </Grid>
</Window>
