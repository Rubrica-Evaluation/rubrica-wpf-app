<UserControl x:Class="GradingTool.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E8E8E8"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource Workspace_Title}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#333333"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="&#xE713;"
                        FontSize="24"
                        Command="{Binding NavigateToConfigurationCommand}"
                        Style="{StaticResource IconButton}"
                        ToolTip="{DynamicResource Workspace_Tooltip_Settings}"/>
            </Grid>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- Panneau gauche - Navigation -->
        <Border Grid.Column="0"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,1,0"
                Background="White"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section Sessions -->
                <Grid Grid.Row="3"
                      Margin="0,0,0,10"
                      Visibility="{Binding IsSessionsRootConfigured, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Workspace_Sessions}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="&#xE710;"
                            Command="{Binding CreateNewSessionCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="0,0,4,0"
                            ToolTip="{DynamicResource Workspace_Tooltip_CreateSession}"/>

                    <Button Grid.Column="2"
                            Content="&#xE70F;"
                            Command="{Binding EditSessionCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="0,0,4,0"
                            ToolTip="{DynamicResource Workspace_Tooltip_RenameSession}"/>

                    <Button Grid.Column="3"
                            Content="&#xE74D;"
                            Command="{Binding DeleteSessionCommand}"
                            Style="{StaticResource DangerIconButton}"
                            ToolTip="{DynamicResource Workspace_Tooltip_DeleteSession}"/>
                </Grid>

                <ComboBox Grid.Row="5"
                          ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          Margin="0,0,0,10"
                          Style="{StaticResource ModernComboBox}"
                          Visibility="{Binding IsSessionsRootConfigured, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Section Cours -->
                <Grid Grid.Row="6"
                      Margin="0,20,0,12"
                      Visibility="{Binding IsSessionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Workspace_Courses}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="&#xE710;"
                            Command="{Binding CreateNewCourseCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="0,0,4,0"
                            ToolTip="{DynamicResource Workspace_Tooltip_CreateCourse}"/>

                    <Button Grid.Column="2"
                            Content="&#xE70F;"
                            Command="{Binding EditCourseCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="0,0,4,0"
                            ToolTip="{DynamicResource Workspace_Tooltip_RenameCourse}"/>

                    <Button Grid.Column="3"
                            Content="&#xE74D;"
                            Command="{Binding DeleteCourseCommand}"
                            Style="{StaticResource DangerIconButton}"
                            ToolTip="{DynamicResource Workspace_Tooltip_DeleteCourse}"/>
                </Grid>

                <ListBox Grid.Row="7"
                         ItemsSource="{Binding Courses}"
                         SelectedItem="{Binding SelectedCourse}"
                         FontSize="13"
                         Padding="8"
                         BorderBrush="#E0E0E0"
                         BorderThickness="1"
                         MaxHeight="200"
                         MinHeight="50"
                         Visibility="{Binding IsSessionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}"/>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Section Évaluations -->
                <Grid Grid.Row="8"
                      Margin="0,20,0,12"
                      Visibility="{Binding IsCourseSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Workspace_Evaluations}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="&#xE710;"
                            Command="{Binding CreateNewWorkCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="0,0,4,0"
                            ToolTip="{DynamicResource Workspace_Tooltip_CreateWork}"/>

                    <Button Grid.Column="2"
                            Content="&#xE70F;"
                            Command="{Binding EditWorkCommand}"
                            Style="{StaticResource IconButton}"
                            Margin="0,0,4,0"
                            ToolTip="{DynamicResource Workspace_Tooltip_RenameWork}"/>

                    <Button Grid.Column="3"
                            Content="&#xE74D;"
                            Command="{Binding DeleteWorkCommand}"
                            Style="{StaticResource DangerIconButton}"
                            ToolTip="{DynamicResource Workspace_Tooltip_DeleteWork}"/>
                </Grid>

                <ListBox Grid.Row="10"
                         ItemsSource="{Binding Works}"
                         SelectedItem="{Binding SelectedWork}"
                         FontSize="13"
                         Padding="8"
                         BorderBrush="#E0E0E0"
                         BorderThickness="1"
                         Visibility="{Binding IsCourseSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource SelectableListBoxItemStyle}"/>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Panneau droit - Contenu principal -->
        <Grid Grid.Column="1" Margin="20">
            <!-- Message si aucune évaluation sélectionnée -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedWork}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{DynamicResource Workspace_Title}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource Workspace_SelectWorkPrompt}"
                           FontSize="16"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="500"/>
            </StackPanel>

            <!-- Détails de l'évaluation -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedWork, Converter={StaticResource NullToBoolConverter}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel>
                    <TextBlock Text="{DynamicResource Workspace_WorkDetails}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#333333"
                               Margin="0,0,0,20"/>

                    <TextBlock FontSize="16"
                               Foreground="#666666"
                               Margin="0,0,0,20">
                        <Run Text="{DynamicResource Workspace_EvaluationLabel}"/>
                        <Run Text="{Binding SelectedWork, FallbackValue='N/A'}" FontWeight="SemiBold" Foreground="#333333"/>
                    </TextBlock>

                    <!-- Section Rubrique -->
                    <TextBlock Text="{DynamicResource Workspace_RubricSection}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="0,0,0,16"/>

                    <Border Background="White"
                            CornerRadius="8"
                            BorderBrush="#E8E8E8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Statut de la rubrique -->
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       ToolTip="{DynamicResource Workspace_Tooltip_RubricStatus}">
                                <Run Text="{Binding RubricStatusText}"/>
                                <Run.Foreground>
                                    <SolidColorBrush Color="{Binding RubricStatusColor}"/>
                                </Run.Foreground>
                            </TextBlock>

                            <!-- Boutons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource Workspace_BtnRubricDesigner}"
                                        Command="{Binding OpenRubricDesignerCommand}"
                                        Style="{StaticResource RoundedButton}"
                                        FontSize="13"
                                        Padding="16,8"
                                        Margin="0,0,0,0"
                                        ToolTip="{DynamicResource Workspace_Tooltip_RubricDesigner}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Section Étudiants -->
                    <TextBlock Text="{DynamicResource Workspace_StudentsSection}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="0,24,0,16"/>

                    <Border Background="White"
                            CornerRadius="8"
                            BorderBrush="#E8E8E8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Statut du roster -->
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       ToolTip="{DynamicResource Workspace_Tooltip_RosterStatus}">
                                <Run Text="{Binding RosterStatusText}"/>
                                <Run.Foreground>
                                    <SolidColorBrush Color="{Binding RosterStatusColor}"/>
                                </Run.Foreground>
                            </TextBlock>

                            <!-- Liste des groupes avec boutons inline -->
                            <ItemsControl ItemsSource="{Binding Groups}"
                                          Visibility="{Binding RosterExists, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Margin="0,0,0,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#D8E8F8"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="10,8"
                                                Margin="0,0,0,6"
                                                Background="#F8FBFF">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DisplayName}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0078D4"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="{DynamicResource Workspace_BtnGenerateGrids}"
                                                            Command="{Binding DataContext.GenerateGroupGridsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding DataContext.RubricExists, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Style="{StaticResource RoundedButton}"
                                                            FontSize="12"
                                                            Padding="12,6"
                                                            Margin="0,0,8,0"
                                                            ToolTip="{DynamicResource Workspace_Tooltip_GenerateGrids}"/>
                                                    <Button Content="{DynamicResource Workspace_BtnOpenEditor}"
                                                            Command="{Binding DataContext.NavigateToGridEditorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RoundedButton}"
                                                            FontSize="12"
                                                            Padding="12,6"
                                                            ToolTip="{DynamicResource Workspace_Tooltip_OpenEditor}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Options de génération pour équipes -->
                            <Border Background="#FFFBF2"
                                    BorderBrush="#F0C040"
                                    BorderThickness="3,0,0,0"
                                    CornerRadius="0,4,4,0"
                                    Padding="12"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding HasTeams, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Workspace_GenerationMode}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Margin="0,0,0,8"/>

                                    <RadioButton Content="{DynamicResource Workspace_GenerationModeIndividual}"
                                                 IsChecked="{Binding GenerationMode, Converter={StaticResource GenerationModeConverter}, ConverterParameter=individual}"
                                                 GroupName="GenerationMode"
                                                 FontSize="13"
                                                 Margin="0,0,0,4"
                                                 ToolTip="{DynamicResource Workspace_Tooltip_ModeIndividual}"/>

                                    <RadioButton Content="{DynamicResource Workspace_GenerationModeTeam}"
                                                 IsChecked="{Binding GenerationMode, Converter={StaticResource GenerationModeConverter}, ConverterParameter=team}"
                                                 GroupName="GenerationMode"
                                                 FontSize="13"
                                                 ToolTip="{DynamicResource Workspace_Tooltip_ModeTeam}"/>
                                </StackPanel>
                            </Border>

                            <!-- Bouton global -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource Workspace_BtnEditRoster}"
                                        Command="{Binding OpenRosterEditorCommand}"
                                        Style="{StaticResource RoundedButton}"
                                        FontSize="13"
                                        Padding="16,8"
                                        ToolTip="{DynamicResource Workspace_Tooltip_EditRoster}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
