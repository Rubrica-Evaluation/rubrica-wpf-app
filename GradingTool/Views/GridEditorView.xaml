<UserControl x:Class="GradingTool.Views.GridEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:GradingTool.Helpers"
             xmlns:models="clr-namespace:GradingTool.Models"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête avec chemin et bouton retour -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#E8E8E8" 
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Chemin: Session/Cours/Travail/Groupe -->
                <TextBlock Grid.Column="0"
                           Text="{Binding NavigationPath}"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="#5C5C5C"/>

                <!-- Boutons -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right">
                    <Button Content="Produire sommaire"
                            Command="{Binding ExportSummaryCommand}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}"
                            ToolTip="Générer un fichier csv des résultats de tous les étudiants du groupe (pour importation Léa)"/>
                    <Button Content="Exporter PDF"
                            Command="{Binding ExportPdfCommand}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            Style="{StaticResource DangerButton}"
                            ToolTip="Exporter toutes les grilles du groupe en PDF (et travaux.zip)"/>
                    <Button Content="Enregistrer"
                            Command="{Binding SaveCommand}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            Style="{StaticResource RoundedButton}"
                            ToolTip="Enregistrer les modifications de la grille courante"/>
                    <Button Content="Retour"
                            Command="{Binding GoBackCommand}"
                            Padding="16,8"
                            Style="{StaticResource GhostButton}"
                            ToolTip="Retourner à l'espace de travail"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panneau gauche - Liste des fichiers JSON -->
            <Border Grid.Column="0" 
                    Background="#FAFAFA" 
                    BorderBrush="#E8E8E8" 
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Titre de la section -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="Grilles du groupe"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Foreground="#1A1A1A"
                               Padding="16,12"
                               Background="White"
                               TextAlignment="Center"/>

                    <!-- Liste des fichiers -->
                    <ListBox ItemsSource="{Binding GridFiles}"
                             SelectedItem="{Binding SelectedGridFile}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="8">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8"
                                        Margin="0,4"
                                        CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="Background" Value="#BBDEFB"/>
                                                    <Setter Property="BorderBrush" Value="#1976D2"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTeam}" Value="True">
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Foreground" Value="#0D6EFD"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTeam}" Value="False">
                                                            <Setter Property="Foreground" Value="#333333"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding MembersDisplay}"
                                                   FontSize="13"
                                                   Foreground="#333333"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTeam}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Panneau droit - Informations du fichier sélectionné -->
            <Grid Grid.Column="1" Background="White">
                <DockPanel>
                    <!-- En-tête de l'éditeur avec 3 colonnes -->
                    <Border DockPanel.Dock="Top"
                            Background="White"
                            BorderBrush="#E8E8E8"
                            BorderThickness="0,0,0,1"
                            Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Colonne 1: Noms des étudiants -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Étudiants" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C5C5C"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding SelectedGridFile.MembersWithDaDisplay}"
                                           FontSize="13"
                                           Foreground="#5C5C5C"
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </StackPanel>

                            <!-- Colonne 2: Total des pénalités -->
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Pénalités appliquées" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C5C5C"
                                           Margin="0,0,0,6"/>
                                <Border Background="#FFFBF2" 
                                        BorderBrush="#F0C040"
                                        BorderThickness="3,0,0,0"
                                        CornerRadius="0,4,4,0"
                                        Padding="12">
                                    <TextBlock Text="{Binding TotalPenalties, StringFormat={}{0:F1} pts}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#7A5D00"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Colonne 3: Total des points -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Total des points" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C5C5C"
                                           Margin="0,0,0,6"/>
                                <Border Background="#EBF4FC" 
                                        BorderBrush="#B3D4F5"
                                        BorderThickness="3,0,0,0"
                                        CornerRadius="0,4,4,0"
                                        Padding="12">
                                    <TextBlock Text="{Binding TotalPoints, StringFormat={}{0:F1} pts}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#0078D4"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Espace pour le contenu de l'éditeur -->
                    <ScrollViewer Padding="20">
                        <StackPanel>
                            <!-- Titre Critères -->
                            <TextBlock Text="Critères"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"
                                       Margin="0,0,0,16"/>
                            
                            <ItemsControl ItemsSource="{Binding CurrentGrid.Criteria}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" 
                                                BorderThickness="0,0,0,1" 
                                                Padding="0,16"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <!-- Label du critère -->
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#333333"
                                                           Margin="0,0,0,12"/>
                                                
                                                <!-- Contrôles d'édition -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Label et Dropdown pour le résultat -->
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock FontSize="12"
                                                                   Foreground="#666666"
                                                                   Margin="0,0,0,4">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="Résultat - {0:F1} pts">
                                                                    <Binding Path="Points"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <ComboBox x:Name="resultComboBox"
                                                                  ItemsSource="{Binding Scale}"
                                                                  SelectedValue="{Binding Result}"
                                                                  SelectedValuePath="Qualitative"
                                                                  helpers:ScrollHelper.BubbleToParent="True">
                                                            <ComboBox.Style>
                                                                <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Result}" Value="">
                                                                            <Setter Property="SelectedIndex" Value="0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ComboBox.Style>
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock>
                                                                        <TextBlock.Text>
                                                                            <MultiBinding StringFormat="{}{0} - {1} ({2} %)">
                                                                                <Binding Path="Qualitative"/>
                                                                                <Binding Path="Label"/>
                                                                                <Binding Path="Points"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <!-- Recommendation basée sur les commentaires -->
                                                        <Button Margin="0,4,0,0"
                                                                Padding="0"
                                                                BorderThickness="0"
                                                                Background="Transparent"
                                                                HorizontalAlignment="Left"
                                                                Cursor="Hand"
                                                                ToolTip="Cliquer pour appliquer cette suggestion"
                                                                Visibility="{Binding HasRecommendation, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Command="{Binding DataContext.ApplyRecommendationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}">
                                                            <Border Background="#EBF5FB"
                                                                    BorderBrush="#AED6F1"
                                                                    BorderThickness="1"
                                                                    CornerRadius="3"
                                                                    Padding="6,4">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                                                <Setter Property="Background" Value="#D6EAF8"/>
                                                                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="💡"
                                                                               FontSize="11"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,4,0"/>
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="#1A5276"
                                                                               VerticalAlignment="Center">
                                                                        <TextBlock.Text>
                                                                            <Binding Path="RecommendedResult" StringFormat="Suggestion : {0}"/>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </StackPanel>
                                                    
                                                    <!-- Espace -->
                                                    <TextBlock Grid.Column="1"/>
                                                    
                                                    <!-- Label et Champ Rétroaction -->
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Rétroaction"
                                                                   FontSize="12"
                                                                   Foreground="#666666"
                                                                   Margin="0,0,0,4"/>
                                                        
                                                        <!-- Liste des feedbacks -->
                                                        <Border BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                ClipToBounds="True"
                                                                Margin="0,0,0,8">
                                                        <ListBox ItemsSource="{Binding Feedback}"
                                                                 x:Name="FeedbackList"
                                                                 helpers:ScrollHelper.BubbleToParent="True"
                                                                 SelectedItem="{Binding DataContext.SelectedFeedbackItem, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                                                                 MinHeight="60"
                                                                 MaxHeight="160"
                                                                 Background="White"
                                                                 BorderThickness="0"
                                                                 HorizontalContentAlignment="Stretch"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                    <Setter Property="Padding" Value="0"/>
                                                                    <Setter Property="Margin" Value="0"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <ContentPresenter/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="8,6"
                                                                            Margin="4,2"
                                                                            CornerRadius="6"
                                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                        <Border.ToolTip>
                                                                            <ToolTip MaxWidth="360">
                                                                                <TextBlock TextWrapping="Wrap">
                                                                                    <TextBlock.Text>
                                                                                        <MultiBinding Converter="{StaticResource CommentUsageTooltipConverter}">
                                                                                            <Binding Path="PlacementTarget.DataContext" RelativeSource="{RelativeSource AncestorType=ToolTip}"/>
                                                                                            <Binding Path="PlacementTarget.Tag" RelativeSource="{RelativeSource AncestorType=ToolTip}"/>
                                                                                        </MultiBinding>
                                                                                    </TextBlock.Text>
                                                                                </TextBlock>
                                                                            </ToolTip>
                                                                        </Border.ToolTip>
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                                        <Setter Property="Background" Value="#DDEEFB"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <Border Grid.Column="0"
                                                                                    CornerRadius="3"
                                                                                    Padding="4,1"
                                                                                    Margin="0,2,6,0"
                                                                                    VerticalAlignment="Top"
                                                                                    Background="{Binding Severity, Converter={StaticResource SeverityColorConverter}}">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:CommentSeverity.Aucun}">
                                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <TextBlock Text="{Binding Severity}"
                                                                                           FontSize="10"
                                                                                           Foreground="White"
                                                                                           FontWeight="SemiBold"/>
                                                                            </Border>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding Text}"
                                                                                       TextWrapping="Wrap"
                                                                                       FontSize="12"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                        </Border>
                                                        
                                                        <!-- StackPanel pour les boutons d'action -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <!-- Boutons -->
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="&#xE710;"
                                                                        Style="{StaticResource IconButton}"
                                                                        ToolTip="Ajouter un commentaire"
                                                                        Margin="0,0,2,0"
                                                                        Command="{Binding DataContext.AddFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                                <Button Content="&#xE70F;"
                                                                        Style="{StaticResource IconButton}"
                                                                        ToolTip="Modifier le commentaire sélectionné"
                                                                        Margin="0,0,2,0"
                                                                        Command="{Binding DataContext.EditFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                                <Button Content="&#xE74D;"
                                                                        Style="{StaticResource DangerIconButton}"
                                                                        ToolTip="Supprimer le commentaire sélectionné"
                                                                        Command="{Binding DataContext.DeleteFeedbackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                            
                                                            <!-- Bouton banque de commentaires -->
                                                            <Button Content="Banque"
                                                                    Padding="12,0"
                                                                    Margin="8,0,0,0"
                                                                    FontSize="12"
                                                                    Style="{StaticResource GhostButton}"
                                                                    ToolTip="Choisir un commentaire depuis la banque"
                                                                    Command="{Binding DataContext.OpenCommentPickerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                        
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Titre Pénalités -->
                            <TextBlock Text="Pénalités"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"
                                       Margin="0,32,0,16"/>
                            
                            <ItemsControl ItemsSource="{Binding CurrentGrid.Penalties}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" 
                                                BorderThickness="0,0,0,1" 
                                                Padding="0,16"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <!-- Label de la pénalité -->
                                                <TextBlock FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#333333"
                                                           Margin="0,0,0,12">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} ({1:F1} pts)">
                                                            <Binding Path="Label"/>
                                                            <Binding Path="ComputedPenalty"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                
                                                <!-- Contrôles d'édition -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Champ Count -->
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Nombre"
                                                                   FontSize="12"
                                                                   Foreground="#666666"
                                                                   Margin="0,0,0,4"/>
                                                        <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="32"
                                                                 Padding="8,4"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Espace -->
                                                    <TextBlock Grid.Column="1"/>
                                                    
                                                    <!-- Champ Reason -->
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Raison"
                                                                   FontSize="12"
                                                                   Foreground="#666666"
                                                                   Margin="0,0,0,4"/>
                                                        <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                                                 MinHeight="32"
                                                                 Padding="8,4"
                                                                 VerticalContentAlignment="Top"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
