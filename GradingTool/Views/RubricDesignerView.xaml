<UserControl x:Class="GradingTool.Views.RubricDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1280"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E8E8E8"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding NavigationPath}"
                               FontSize="16"
                               Foreground="#5C5C5C"
                               Margin="0,0,0,3"/>
                    <TextBlock Text="{DynamicResource RubricDesigner_Subtitle}"
                               FontSize="12"
                               Foreground="#9E9E9E"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="{DynamicResource RubricDesigner_BtnLoadRubric}"
                            Command="{Binding LoadRubricFromFileCommand}"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            ToolTip="{DynamicResource RubricDesigner_Tooltip_LoadRubric}"/>
                    <Button Content="{DynamicResource RubricDesigner_BtnNewRubric}"
                            Command="{Binding NewRubricCommand}"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            ToolTip="{DynamicResource RubricDesigner_Tooltip_NewRubric}"/>
                    <Button Content="{DynamicResource Common_Save}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource RoundedButton}"
                            Margin="0,0,8,0"
                            ToolTip="{DynamicResource RubricDesigner_Tooltip_Save}"/>
                    <Button Content="{DynamicResource Common_Back}"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource GhostButton}"
                            ToolTip="{DynamicResource RubricDesigner_Tooltip_Back}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="White"
                            CornerRadius="8"
                            BorderBrush="#E8E8E8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource RubricDesigner_Settings}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="{DynamicResource RubricDesigner_WorkName}"
                                       FontSize="13"
                                       Foreground="#666666"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TpName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     FontSize="14"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="{DynamicResource RubricDesigner_Summary}"
                                       FontSize="13"
                                       Foreground="#666666"
                                       Margin="0,0,0,8"/>

                            <Border Background="#FAFAFA"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding CriteriaCountText}"
                                               FontSize="14"
                                               Foreground="#333333"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding PenaltiesCountText}"
                                               FontSize="14"
                                               Foreground="#333333"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TotalWeightText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               ToolTip="Affiche la somme des poids de tous les critères. Idéalement, le total devrait atteindre 100 % .">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#333333"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalWeight}" Value="100">
                                                        <Setter Property="Foreground" Value="#198754"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{DynamicResource RubricDesigner_InfoNote}"
                                       FontSize="12"
                                       Foreground="#6C757D"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFBF2"
                            BorderBrush="#F0C040"
                            BorderThickness="3,0,0,0"
                            CornerRadius="0,6,6,0"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource RubricDesigner_Tips}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#7A5D00"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource RubricDesigner_Tip1}"
                                       FontSize="12"
                                       Foreground="#7A5D00"
                                       Margin="0,0,0,4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{DynamicResource RubricDesigner_Tip2}"
                                       FontSize="12"
                                       Foreground="#7A5D00"
                                       Margin="0,0,0,4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{DynamicResource RubricDesigner_Tip3}"
                                       FontSize="12"
                                       Foreground="#7A5D00"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Background="White"
                            CornerRadius="8"
                            BorderBrush="#E8E8E8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{DynamicResource RubricDesigner_CriteriaSection}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>

                            <Button Grid.Column="1"
                                    Content="{DynamicResource RubricDesigner_BtnAddCriterion}"
                                    Command="{Binding AddCriterionCommand}"
                                    Style="{StaticResource RoundedButton}"
                                    Padding="16,8"
                                    ToolTip="{DynamicResource RubricDesigner_Tooltip_AddCriterion}"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Criteria}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E8E8E8"
                                        BorderThickness="1"
                                        Padding="16"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="{DynamicResource RubricDesigner_CriterionLabel}"
                                                           FontSize="12"
                                                           Foreground="#666666"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="10,8"
                                                         FontSize="14"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="{DynamicResource RubricDesigner_CriterionWeight}"
                                                           FontSize="12"
                                                           Foreground="#666666"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="10,8"
                                                         FontSize="14"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="{DynamicResource Common_Delete}"
                                                    Command="{Binding DataContext.RemoveCriterionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="14,8"
                                                    VerticalAlignment="Bottom"
                                                    ToolTip="{DynamicResource RubricDesigner_Tooltip_DeleteCriterion}"/>
                                        </Grid>

                                        <Border Background="#F8F9FA"
                                                BorderBrush="#E9ECEF"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{DynamicResource RubricDesigner_ScaleItems}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#333333"/>

                                                    <Button Grid.Column="1"
                                                            Content="{DynamicResource RubricDesigner_BtnAddScaleItem}"
                                                            Command="{Binding DataContext.AddScaleItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RoundedButton}"
                                                            Padding="14,6"
                                                            Background="#198754"
                                                            ToolTip="{DynamicResource RubricDesigner_Tooltip_AddScaleItem}"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding Scale}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource RubricDesigner_ScaleQualitative}"
                                                                           FontSize="12"
                                                                           Foreground="#666666"
                                                                           Margin="0,0,8,6"/>
                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="1"
                                                                           Text="{DynamicResource RubricDesigner_ScaleDescription}"
                                                                           FontSize="12"
                                                                           Foreground="#666666"
                                                                           Margin="0,0,8,6"/>
                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="2"
                                                                           Text="{DynamicResource RubricDesigner_ScalePoints}"
                                                                           FontSize="12"
                                                                           Foreground="#666666"
                                                                           Margin="0,0,8,6"/>

                                                                <TextBox Grid.Row="1"
                                                                         Grid.Column="0"
                                                                         Text="{Binding Qualitative, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="10,8"
                                                                         Margin="0,0,8,0"/>
                                                                <TextBox Grid.Row="1"
                                                                         Grid.Column="1"
                                                                         Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="10,8"
                                                                         Margin="0,0,8,0"/>
                                                                <TextBox Grid.Row="1"
                                                                         Grid.Column="2"
                                                                         Text="{Binding Points, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="10,8"
                                                                         Margin="0,0,8,0"/>
                                                                <Button Grid.Row="1"
                                                                        Grid.Column="3"
                                                                        Content="&#xE74D;"
                                                                        Command="{Binding DataContext.RemoveScaleItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource DangerIconButton}"
                                                                        ToolTip="{DynamicResource RubricDesigner_Tooltip_DeleteScale}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="White"
                            CornerRadius="8"
                            BorderBrush="#E8E8E8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,8,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{DynamicResource RubricDesigner_PenaltiesSection}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>

                            <Button Grid.Column="1"
                                    Content="{DynamicResource RubricDesigner_BtnAddPenalty}"
                                    Command="{Binding AddPenaltyCommand}"
                                    Style="{StaticResource RoundedButton}"
                                    Padding="16,8"
                                    ToolTip="{DynamicResource RubricDesigner_Tooltip_AddPenalty}"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Penalties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E8E8E8"
                                        BorderThickness="1"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{DynamicResource RubricDesigner_PenaltyLabel}"
                                                   FontSize="12"
                                                   Foreground="#666666"
                                                   Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{DynamicResource RubricDesigner_PenaltyFactor}"
                                                   FontSize="12"
                                                   Foreground="#666666"
                                                   Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="{DynamicResource RubricDesigner_PenaltyMin}"
                                                   FontSize="12"
                                                   Foreground="#666666"
                                                   Margin="0,0,8,6"/>

                                        <TextBox Grid.Row="1"
                                                 Grid.Column="0"
                                                 Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8"
                                                 Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Text="{Binding Factor, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8"
                                                 Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="2"
                                                 Text="{Binding Min, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8"
                                                 Margin="0,0,8,0"/>
                                        <Button Grid.Row="1"
                                                Grid.Column="3"
                                                Content="{DynamicResource Common_Delete}"
                                                Command="{Binding DataContext.RemovePenaltyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButton}"
                                                Padding="14,8"
                                                ToolTip="{DynamicResource RubricDesigner_Tooltip_DeletePenalty}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
