<UserControl x:Class="GradingTool.Views.RubricDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1280"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F8F9FA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding NavigationPath}"
                               FontSize="18"
                               Foreground="#444444"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Concevez la rubrique du travail: critères, niveaux qualitatifs et pénalités."
                               FontSize="13"
                               Foreground="#6C757D"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Charger une rubrique"
                            Command="{Binding LoadRubricFromFileCommand}"
                            Style="{StaticResource RoundedButton}"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Background="#17A2B8"
                            ToolTip="Importer un fichier rubric.json existant dans le concepteur pour le consulter ou le modifier"/>
                    <Button Content="Nouvelle rubrique"
                            Command="{Binding NewRubricCommand}"
                            Style="{StaticResource RoundedButton}"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Background="#6C757D"
                            ToolTip="Réinitialiser le concepteur avec une rubrique vide"/>
                    <Button Content="Enregistrer"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource RoundedButton}"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Background="#28A745"
                            ToolTip="Valider et enregistrer la rubrique comme rubric.json pour ce travail"/>
                    <Button Content="Retour"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource RoundedButton}"
                            Padding="18,8"
                            Background="#495057"
                            ToolTip="Retourner à la page d'accueil"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="#F8F9FA"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Paramètres"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Nom du travail"
                                       FontSize="13"
                                       Foreground="#666666"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TpName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"
                                     FontSize="14"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="Résumé"
                                       FontSize="13"
                                       Foreground="#666666"
                                       Margin="0,0,0,8"/>

                            <Border Background="White"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding CriteriaCount, StringFormat=Critères: {0}}"
                                               FontSize="14"
                                               Foreground="#333333"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding PenaltiesCount, StringFormat=Pénalités: {0}}"
                                               FontSize="14"
                                               Foreground="#333333"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TotalWeight, StringFormat=Poids total: {0} %}"
                                               FontSize="14"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#333333"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalWeight}" Value="100">
                                                        <Setter Property="Foreground" Value="#198754"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="La rubrique enregistrée remplacera rubric.json pour ce travail."
                                       FontSize="12"
                                       Foreground="#6C757D"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8E1"
                            BorderBrush="#FFCA2C"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Conseils"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#7A5D00"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="1. Ajoutez un critère par dimension évaluée."
                                       FontSize="13"
                                       Foreground="#7A5D00"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="2. Définissez les niveaux qualitatifs avec leur pourcentage."
                                       FontSize="13"
                                       Foreground="#7A5D00"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="3. Décrivez les pénalités appliquées au travail."
                                       FontSize="13"
                                       Foreground="#7A5D00"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Background="#F5F5F5"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Critères et niveaux qualitatifs"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>

                            <Button Grid.Column="1"
                                    Content="Ajouter un critère"
                                    Command="{Binding AddCriterionCommand}"
                                    Style="{StaticResource RoundedButton}"
                                    Padding="16,8"
                                    Background="#0D6EFD"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Criteria}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#DEE2E6"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="16"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Libellé du critère"
                                                           FontSize="12"
                                                           Foreground="#666666"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="10,8"
                                                         FontSize="14"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="Poids (%)"
                                                           FontSize="12"
                                                           Foreground="#666666"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="10,8"
                                                         FontSize="14"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="Supprimer"
                                                    Command="{Binding DataContext.RemoveCriterionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource RoundedButton}"
                                                    Padding="16,8"
                                                    Background="#DC3545"
                                                    VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <Border Background="#F8F9FA"
                                                BorderBrush="#E9ECEF"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Niveaux qualitatifs"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#333333"/>

                                                    <Button Grid.Column="1"
                                                            Content="Ajouter un niveau"
                                                            Command="{Binding DataContext.AddScaleItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RoundedButton}"
                                                            Padding="14,6"
                                                            Background="#198754"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding Scale}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBox Grid.Column="0"
                                                                         Text="{Binding Qualitative, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="10,8"
                                                                         Margin="0,0,8,0"/>
                                                                <TextBox Grid.Column="1"
                                                                         Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="10,8"
                                                                         Margin="0,0,8,0"/>
                                                                <TextBox Grid.Column="2"
                                                                         Text="{Binding Points, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="10,8"
                                                                         Margin="0,0,8,0"/>
                                                                <Button Grid.Column="3"
                                                                        Content="X"
                                                                        Command="{Binding DataContext.RemoveScaleItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource RoundedButton}"
                                                                        Padding="12,6"
                                                                        Background="#DC3545"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="#F5F5F5"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,8,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Pénalités du travail"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#333333"/>

                            <Button Grid.Column="1"
                                    Content="Ajouter une pénalité"
                                    Command="{Binding AddPenaltyCommand}"
                                    Style="{StaticResource RoundedButton}"
                                    Padding="16,8"
                                    Background="#FD7E14"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Penalties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#DEE2E6"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8"
                                                 Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Factor, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8"
                                                 Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Min, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8"
                                                 Margin="0,0,8,0"/>
                                        <Button Grid.Column="3"
                                                Content="Supprimer"
                                                Command="{Binding DataContext.RemovePenaltyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource RoundedButton}"
                                                Padding="16,8"
                                                Background="#DC3545"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>